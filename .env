# ── Zahlung ────────────────────────────────────────────────────────────────────
# Dein PayPal.me-Link (z.B. https://paypal.me/deinname/2EUR)
PAYPAL_LINK=https://paypal.me/DEIN_PAYPAL/2

# Monatlicher Preis (nur zur Anzeige)
PRICE_EUR=2

# Admin-Passwort für das Admin-Panel (wird auto-generiert wenn leer)
# ADMIN_PASSWORD=

# ── E-Mail (für Verifizierungscodes) ──────────────────────────────────────────
# Gmail empfohlen: 2FA aktivieren → App-Passwort erstellen → hier eintragen
# https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=deine@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── App ────────────────────────────────────────────────────────────────────────
PORT=3333
CLIENT_URL=https://welias123.github.io/pulsewave-website
