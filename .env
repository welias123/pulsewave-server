# ── PayPal Subscription ────────────────────────────────────────────────────────
# 1. Geh zu: https://www.paypal.com/buttons/
# 2. Wähle "Abonnement" / "Subscribe"
# 3. Preis: €2/Monat, Abrechnungszyklus: Monatlich
# 4. Rückgabe-URL: https://welias123.github.io/pulsewave-website?premium=success
# 5. IPN-URL im PayPal-Konto setzen: https://pulsewave-welias.loca.lt/api/paypal-ipn
#    → paypal.com → Einstellungen → Benachrichtigungen → Sofortige Zahlungsbenachrichtigungen
# 6. Button-Code kopieren → "hosted_button_id" hier eintragen:
PAYPAL_BUTTON_ID=DEINE_BUTTON_ID_HIER

# Preis (nur zur Anzeige auf der Website)
PRICE_EUR=2

# Auf true setzen wenn du zuerst in der Sandbox testen willst
PAYPAL_SANDBOX=false

# Admin-Passwort (wird auto-generiert wenn leer gelassen)
# ADMIN_PASSWORD=

# ── E-Mail (für Verifizierungscodes) ──────────────────────────────────────────
EMAIL_SERVICE=gmail
EMAIL_USER=deine@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── App ────────────────────────────────────────────────────────────────────────
PORT=3333
CLIENT_URL=https://welias123.github.io/pulsewave-website
